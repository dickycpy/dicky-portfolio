rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - description: string (required, 1-500 chars)
    //   - category: string (required, enum: ['Artificial Intelligence', 'Digital Marketing', 'Interactive Experience'])
    //   - type: string (optional, enum: ['main', 'lab'])
    //   - sortOrder: number (optional)
    //   - image: string (required, URL)
    //   - role: string (optional, 1-100 chars)
    //   - timeline: string (optional, 1-100 chars)
    //   - tools: list (optional, max 20 items)
    //   - overview: string (optional, 1-5000 chars)
    //   - problem: string (optional, 1-5000 chars)
    //   - solution: string (optional, 1-5000 chars)
    //   - impact: string (optional, 1-5000 chars)
    //   - order: number (optional, for display sorting)
    //   - imageUrl: string (optional, temporary field)
    //   - challenge: string (optional, 1-10000 chars)
    //   - approach: string (optional, 1-10000 chars)
    //   - understanding: string (optional, 1-10000 chars)
    //   - define: string (optional, 1-10000 chars)
    //   - developDeliver: string (optional, 1-10000 chars)
    //   - reflection: string (optional, 1-10000 chars)
    //   - createdAt: timestamp (required)
    //   - authorId: string (required, UID)
    //
    // Collection: users
    // Fields:
    //   - email: string (required, email)
    //   - role: string (required, enum: ['admin', 'user'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "dicky.chu.ibm@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      let requiredFields = ['title', 'description', 'category', 'image', 'createdAt', 'authorId'];
      let newFields = ['introduction', 'challenge', 'approach', 'understanding', 'define', 'developDeliver', 'reflection'];
      let mediaFields = [
        'introductionImage', 'introductionVideo', 'introductionImageDescription',
        'challengeImage', 'challengeVideo', 'challengeImageDescription',
        'approachImage', 'approachVideo', 'approachImageDescription',
        'understandingImage', 'understandingVideo', 'understandingImageDescription',
        'defineImage', 'defineVideo', 'defineImageDescription',
        'developDeliverImage', 'developDeliverVideo', 'developDeliverImageDescription',
        'reflectionImage', 'reflectionVideo', 'reflectionImageDescription'
      ];
      let optionalFields = ['role', 'timeline', 'tools', 'overview', 'problem', 'solution', 'impact', 'password', 'updatedAt', 'imageUrl', 'order', 'type', 'sortOrder', 'subSections'].concat(newFields).concat(mediaFields);
      let allowedFields = requiredFields.concat(optionalFields);
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 1000 &&
             data.category in ['Artificial Intelligence', 'Digital Marketing', 'Interactive Experience'] &&
             (!('type' in data) || (data.type in ['main', 'lab'])) &&
             (!('sortOrder' in data) || (data.sortOrder is number)) &&
             data.image is string && (data.image.matches("^https?://.*") || data.image == "") &&
             data.createdAt is timestamp &&
             data.authorId is string &&
             (!('order' in data) || (data.order is number)) &&
             (!('imageUrl' in data) || (data.imageUrl is string)) &&
             (!('role' in data) || (data.role is string && data.role.size() <= 200)) &&
             (!('timeline' in data) || (data.timeline is string && data.timeline.size() <= 200)) &&
             (!('tools' in data) || (data.tools is list && data.tools.size() <= 50)) &&
             (!('subSections' in data) || (data.subSections is map)) &&
             (!('introduction' in data) || (data.introduction is string && data.introduction.size() <= 20000)) &&
             (!('challenge' in data) || (data.challenge is string && data.challenge.size() <= 20000)) &&
             (!('approach' in data) || (data.approach is string && data.approach.size() <= 20000)) &&
             (!('understanding' in data) || (data.understanding is string && data.understanding.size() <= 20000)) &&
             (!('define' in data) || (data.define is string && data.define.size() <= 20000)) &&
             (!('developDeliver' in data) || (data.developDeliver is string && data.developDeliver.size() <= 20000)) &&
             (!('reflection' in data) || (data.reflection is string && data.reflection.size() <= 20000)) &&
             (!('introductionImage' in data) || (data.introductionImage is string)) &&
             (!('introductionVideo' in data) || (data.introductionVideo is string)) &&
             (!('introductionImageDescription' in data) || (data.introductionImageDescription is string)) &&
             (!('challengeImage' in data) || (data.challengeImage is string)) &&
             (!('challengeVideo' in data) || (data.challengeVideo is string)) &&
             (!('challengeImageDescription' in data) || (data.challengeImageDescription is string)) &&
             (!('approachImage' in data) || (data.approachImage is string)) &&
             (!('approachVideo' in data) || (data.approachVideo is string)) &&
             (!('approachImageDescription' in data) || (data.approachImageDescription is string)) &&
             (!('understandingImage' in data) || (data.understandingImage is string)) &&
             (!('understandingVideo' in data) || (data.understandingVideo is string)) &&
             (!('understandingImageDescription' in data) || (data.understandingImageDescription is string)) &&
             (!('defineImage' in data) || (data.defineImage is string)) &&
             (!('defineVideo' in data) || (data.defineVideo is string)) &&
             (!('defineImageDescription' in data) || (data.defineImageDescription is string)) &&
             (!('developDeliverImage' in data) || (data.developDeliverImage is string)) &&
             (!('developDeliverVideo' in data) || (data.developDeliverVideo is string)) &&
             (!('developDeliverImageDescription' in data) || (data.developDeliverImageDescription is string)) &&
             (!('reflectionImage' in data) || (data.reflectionImage is string)) &&
             (!('reflectionVideo' in data) || (data.reflectionVideo is string)) &&
             (!('reflectionImageDescription' in data) || (data.reflectionImageDescription is string)) &&
             (!('overview' in data) || (data.overview is string && data.overview.size() <= 10000)) &&
             (!('problem' in data) || (data.problem is string && data.problem.size() <= 10000)) &&
             (!('solution' in data) || (data.solution is string && data.solution.size() <= 10000)) &&
             (!('impact' in data) || (data.impact is string && data.impact.size() <= 10000)) &&
             (!('password' in data) || (data.password is string)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && 
                      isValidProject(request.resource.data) && 
                      request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin() && 
                      isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                      request.resource.data.role == 'user' && 
                      isOwner(userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
