rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - description: string (required, 1-500 chars)
    //   - category: string (required, enum: ['Artificial Intelligence', 'Digital Marketing', 'Interactive Experience'])
    //   - image: string (required, URL)
    //   - role: string (optional, 1-100 chars)
    //   - timeline: string (optional, 1-100 chars)
    //   - tools: list (optional, max 20 items)
    //   - overview: string (optional, 1-5000 chars)
    //   - problem: string (optional, 1-5000 chars)
    //   - solution: string (optional, 1-5000 chars)
    //   - impact: string (optional, 1-5000 chars)
    //   - createdAt: timestamp (required)
    //   - authorId: string (required, UID)
    //
    // Collection: users
    // Fields:
    //   - email: string (required, email)
    //   - role: string (required, enum: ['admin', 'user'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "dicky.chu.ibm@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      let requiredFields = ['title', 'description', 'category', 'image', 'createdAt', 'authorId'];
      let newFields = ['introduction', 'challenge', 'approach', 'understanding', 'define', 'developDeliver', 'reflection'];
      let optionalFields = ['role', 'timeline', 'tools', 'overview', 'problem', 'solution', 'impact', 'password', 'updatedAt'].concat(newFields);
      let allowedFields = requiredFields.concat(optionalFields);
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 500 &&
             data.category in ['Artificial Intelligence', 'Digital Marketing', 'Interactive Experience'] &&
             data.image is string && data.image.matches("^https?://.*") &&
             data.createdAt is timestamp &&
             data.authorId is string &&
             (!('role' in data) || (data.role is string && data.role.size() <= 100)) &&
             (!('timeline' in data) || (data.timeline is string && data.timeline.size() <= 100)) &&
             (!('tools' in data) || (data.tools is list && data.tools.size() <= 20)) &&
             (!('introduction' in data) || (data.introduction is string && data.introduction.size() <= 10000)) &&
             (!('challenge' in data) || (data.challenge is string && data.challenge.size() <= 10000)) &&
             (!('approach' in data) || (data.approach is string && data.approach.size() <= 10000)) &&
             (!('understanding' in data) || (data.understanding is string && data.understanding.size() <= 10000)) &&
             (!('define' in data) || (data.define is string && data.define.size() <= 10000)) &&
             (!('developDeliver' in data) || (data.developDeliver is string && data.developDeliver.size() <= 10000)) &&
             (!('reflection' in data) || (data.reflection is string && data.reflection.size() <= 10000)) &&
             (!('overview' in data) || (data.overview is string && data.overview.size() <= 5000)) &&
             (!('problem' in data) || (data.problem is string && data.problem.size() <= 5000)) &&
             (!('solution' in data) || (data.solution is string && data.solution.size() <= 5000)) &&
             (!('impact' in data) || (data.impact is string && data.impact.size() <= 5000)) &&
             (!('password' in data) || (data.password == null || (data.password is string && data.password.size() <= 100))) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && 
                      isValidProject(request.resource.data) && 
                      request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin() && 
                      isValidProject(request.resource.data) &&
                      request.resource.data.authorId == resource.data.authorId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                      request.resource.data.role == 'user' && 
                      isOwner(userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
