{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project item.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The project title." },
        "description": { "type": "string", "description": "A short description." },
        "category": { "type": "string", "description": "The project category." },
        "image": { "type": "string", "format": "url", "description": "The project image URL." },
        "role": { "type": "string", "description": "The author's role." },
        "timeline": { "type": "string", "description": "Project duration." },
        "tools": { "type": "array", "items": { "type": "string" }, "description": "Tools used." },
        "type": { "type": "string", "enum": ["main", "lab"], "description": "Project type: main (career) or lab (freelance)." },
        "sortOrder": { "type": "number", "description": "Custom display order." },
        "overview": { "type": "string", "description": "Detailed overview." },
        "problem": { "type": "string", "description": "Problem statement." },
        "solution": { "type": "string", "description": "Final solution." },
        "impact": { "type": "string", "description": "Impact and metrics." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation timestamp." },
        "authorId": { "type": "string", "description": "The UID of the author." },
        "password": { "type": "string", "description": "Optional password for project access." },
        "imageUrl": { "type": "string", "description": "Temporary image URL used in form." },
        "introduction": { "type": "string", "description": "Introduction content." },
        "challenge": { "type": "string", "description": "Challenge content." },
        "approach": { "type": "string", "description": "Approach content." },
        "understanding": { "type": "string", "description": "Understanding content." },
        "define": { "type": "string", "description": "Define content." },
        "developDeliver": { "type": "string", "description": "Develop & Deliver content." },
        "reflection": { "type": "string", "description": "Reflection content." },
        "introductionImage": { "type": "string", "description": "Optional image for introduction." },
        "introductionVideo": { "type": "string", "description": "Optional video URL for introduction." },
        "challengeImage": { "type": "string", "description": "Optional image for challenge." },
        "challengeVideo": { "type": "string", "description": "Optional video URL for challenge." },
        "approachImage": { "type": "string", "description": "Optional image for approach." },
        "approachVideo": { "type": "string", "description": "Optional video URL for approach." },
        "understandingImage": { "type": "string", "description": "Optional image for understanding." },
        "understandingVideo": { "type": "string", "description": "Optional video URL for understanding." },
        "defineImage": { "type": "string", "description": "Optional image for define." },
        "defineVideo": { "type": "string", "description": "Optional video URL for define." },
        "developDeliverImage": { "type": "string", "description": "Optional image for developDeliver." },
        "developDeliverVideo": { "type": "string", "description": "Optional video URL for developDeliver." },
        "reflectionImage": { "type": "string", "description": "Optional image for reflection." },
        "reflectionVideo": { "type": "string", "description": "Optional video URL for reflection." },
        "introductionImageDescription": { "type": "string", "description": "Description for introduction image." },
        "challengeImageDescription": { "type": "string", "description": "Description for challenge image." },
        "approachImageDescription": { "type": "string", "description": "Description for approach image." },
        "understandingImageDescription": { "type": "string", "description": "Description for understanding image." },
        "defineImageDescription": { "type": "string", "description": "Description for define image." },
        "developDeliverImageDescription": { "type": "string", "description": "Description for developDeliver image." },
        "reflectionImageDescription": { "type": "string", "description": "Description for reflection image." },
        "subSections": {
          "type": "object",
          "description": "Map of section IDs to arrays of sub-sections with media.",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "content": { "type": "string" },
                "image": { "type": "string", "format": "url" },
                "video": { "type": "string", "format": "url" },
                "imageDescription": { "type": "string" },
                "carouselImages": { "type": "array", "items": { "type": "string", "format": "url" }, "description": "Array of image URLs for a carousel." }
              }
            }
          }
        }
      },
      "required": ["title", "description", "category", "image", "createdAt", "authorId"]
    },
    "User": {
      "title": "User",
      "description": "A user profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "projects": {
      "schema": { "$ref": "Project" },
      "description": "Collection of portfolio projects."
    },
    "users": {
      "schema": { "$ref": "User" },
      "description": "Collection of user profiles for RBAC."
    }
  }
}
